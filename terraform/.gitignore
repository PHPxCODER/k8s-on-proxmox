# Local variable files — contain secrets
*.tfvars
*.tfvars.json

# Terraform state — use remote backend in production
*.tfstate
*.tfstate.*
*.tfstate.backup

# Terraform working directories
**/.terraform/
**/.terraform.lock.hcl

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json
